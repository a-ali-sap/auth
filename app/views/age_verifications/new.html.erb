<h2>Age Verification</h2>

<%= form_with(model: @age_verification, local: true) do |f| %>
  <% if @age_verification.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(@age_verification.errors.count, "error") %> prohibited this age verification from being saved:</h4>
      <ul>
        <% @age_verification.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>


  <div class="form-group">
    <%= f.label :date_of_birth %>
    <%= f.date_select :date_of_birth, start_year: 1900, end_year: Date.today.year, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :verification_method %>
    <%= f.select :verification_method, AgeVerification.verification_methods.keys.map { |k| [k.humanize, k] }, {}, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :document, "Upload Document" %>
    <%= f.file_field :document, class: "form-control" %>
  </div>

  <div class="form-group mt-3">
    <%= f.submit "Verify Age", class: "btn btn-primary" %>
  </div>
<% end %>
