<h2>New Participation Space</h2>

<%= form_with(model: [@organization, @participation_space], local: true) do |f| %>
  <% if @participation_space.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(@participation_space.errors.count, "error") %> prohibited this participation space from being saved:</h4>
      <ul>
        <% @participation_space.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :participation_type %>
    <%= f.select :participation_type, ParticipationSpace.participation_types.keys.map { |k| [k.humanize, k] }, {}, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :status %>
    <%= f.select :status, ParticipationSpace.statuses.keys.map { |k| [k.humanize, k] }, {}, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :allowed_age_groups %>
    <%= f.select :allowed_age_groups, %w[child teen adult], {}, multiple: true, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :max_participants %>
    <%= f.number_field :max_participants, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :start_date %>
    <%= f.date_select :start_date, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :end_date %>
    <%= f.date_select :end_date, class: "form-control" %>
  </div>

  <div class="form-group mt-3">
    <%= f.submit "Create Participation Space", class: "btn btn-primary" %>
  </div>
<% end %>

<%= link_to 'Back', organization_participation_spaces_path(@organization), class: 'btn btn-secondary mt-3' %>
